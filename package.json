{
  "name": "edgevision-ai-studio",
  "version": "1.0.0",
  "description": "Next-generation AI Workstation PWA powered by LiteRT.js for on-device AI inference",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.0",
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow/tfjs-backend-cpu": "^4.15.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.15.0",
    "@tensorflow/tfjs-backend-wasm": "^4.15.0",
    "clsx": "^2.1.0",
    "idb": "^7.1.1",
    "litert": "^1.0.0",
    "lucide-react": "^0.312.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "tailwind-merge": "^2.2.1",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.3",
    "@vitest/ui": "^1.1.3",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-pwa": "^0.17.2",
    "vitest": "^1.1.3",
    "workbox-window": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "ai",
    "machine-learning",
    "tensorflow",
    "litert",
    "webgpu",
    "pwa",
    "offline",
    "privacy",
    "computer-vision",
    "nlp",
    "edge-ai",
    "browser-ai"
  ],
  "author": "Abdulraheem Nohari <abdulraheemnohri@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/abdulraheemnohri/EdgeVision-AI-Studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdulraheemnohri/EdgeVision-AI-Studio.git"
  },
  "bugs": {
    "url": "https://github.com/abdulraheemnohri/EdgeVision-AI-Studio/issues"
  }
}