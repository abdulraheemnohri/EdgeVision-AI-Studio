    }
  ],
  "screenshots": [
    {
      "src": "screenshots/desktop-dark.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "EdgeVision AI Studio - Desktop Dark Mode"
    },
    {
      "src": "screenshots/desktop-light.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "EdgeVision AI Studio - Desktop Light Mode"
    },
    {
      "src": "screenshots/mobile-dark.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "EdgeVision AI Studio - Mobile Dark Mode"
    },
    {
      "src": "screenshots/mobile-light.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "EdgeVision AI Studio - Mobile Light Mode"
    }
  ],
  "shortcuts": [
    {
      "name": "New Project",
      "short_name": "New",
      "description": "Create a new AI project",
      "url": "/new-project",
      "icons": [
        {
          "src": "icons/shortcut-new.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Model Manager",
      "short_name": "Models",
      "description": "Manage AI models",
      "url": "/models",
      "icons": [
        {
          "src": "icons/shortcut-models.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "AI Playground",
      "short_name": "Playground",
      "description": "Test AI models interactively",
      "url": "/playground",
      "icons": [
        {
          "src": "icons/shortcut-playground.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Settings",
      "short_name": "Settings",
      "description": "Configure EdgeVision AI Studio",
      "url": "/settings",
      "icons": [
        {
          "src": "icons/shortcut-settings.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "iarc_ratings_id": "",
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "protocol_handlers": [
    {
      "protocol": "web+edgevision",
      "url": "/open?url=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "files",
          "accept": [".tflite", ".json", ".png", ".jpg", ".jpeg"]
        }
      ]
    }
  }
}